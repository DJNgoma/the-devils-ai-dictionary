{
  "name": "devils-ai-dictionary",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://thedevilsaidictionary.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/DJNgoma/the-devils-ai-dictionary.git"
  },
  "bugs": {
    "url": "https://github.com/DJNgoma/the-devils-ai-dictionary/issues"
  },
  "scripts": {
    "content:build": "node scripts/generate-content-index.mjs",
    "predev": "npm run content:build",
    "prebuild": "npm run content:build",
    "dev": "next dev",
    "build": "next build",
    "build:mobile": "NEXT_OUTPUT_MODE=export next build",
    "build:cf": "opennextjs-cloudflare build",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload:cf": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "android:assets": "npx @capacitor/assets generate --android --iconBackgroundColor '#ff5b2c' --iconBackgroundColorDark '#140904' --splashBackgroundColor '#f4efe6' --splashBackgroundColorDark '#12100d'",
    "android:sync": "npm run build:mobile && npx cap sync android",
    "android:open": "npx cap open android",
    "android:prepare": "npm run android:assets && npm run android:sync",
    "android:run": "npm run android:prepare && node scripts/with-android-java.mjs npx cap run android",
    "android:build:debug": "npm run android:prepare && node scripts/with-android-java.mjs sh -lc 'cd android && ./gradlew assembleDebug'",
    "android:build:release:apk": "npm run android:prepare && node scripts/with-android-java.mjs sh -lc 'cd android && ./gradlew assembleRelease'",
    "android:build:release:bundle": "npm run android:prepare && node scripts/with-android-java.mjs sh -lc 'cd android && ./gradlew bundleRelease'",
    "android:install:release": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "ios:assets": "npx @capacitor/assets generate --ios --iconBackgroundColor '#ff5b2c' --iconBackgroundColorDark '#140904' --splashBackgroundColor '#f4efe6' --splashBackgroundColorDark '#12100d'",
    "ios:sync": "npm run build:mobile && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:prepare": "npm run ios:assets && npm run ios:sync",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "swift-core:test": "swift test --package-path shared/swift-core"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.0",
    "@opennextjs/cloudflare": "^1.17.1",
    "clsx": "^2.1.1",
    "flexsearch": "^0.8.212",
    "gray-matter": "^4.0.3",
    "next": "16.1.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@csstools/postcss-cascade-layers": "^6.0.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4",
    "wrangler": "^4.75.0"
  }
}
