{
  "name": "devils-ai-dictionary",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://thedevilsaidictionary.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/DJNgoma/the-devils-ai-dictionary.git"
  },
  "bugs": {
    "url": "https://github.com/DJNgoma/the-devils-ai-dictionary/issues"
  },
  "scripts": {
    "content:build": "node scripts/generate-content-index.mjs",
    "predev": "npm run content:build",
    "prebuild": "npm run content:build",
    "dev": "next dev",
    "build": "next build",
    "build:mobile": "mv src/app/api src/app/_api-server-only 2>/dev/null; NEXT_OUTPUT_MODE=export next build; STATUS=$?; mv src/app/_api-server-only src/app/api 2>/dev/null; exit $STATUS",
    "build:cf": "opennextjs-cloudflare build",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload:cf": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "android:assets": "npx @capacitor/assets generate --android --iconBackgroundColor '#ff5b2c' --iconBackgroundColorDark '#140904' --splashBackgroundColor '#f4efe6' --splashBackgroundColorDark '#12100d' && node scripts/fix-android-assets.mjs",
    "android:open": "open -a 'Android Studio' android",
    "android:prepare": "npm run content:build && npm run android:assets",
    "android:test": "node scripts/with-android-java.mjs ./android/gradlew -p android testDebugUnitTest",
    "android:run": "npm run android:prepare && node scripts/with-android-java.mjs ./android/gradlew -p android installDebug",
    "android:build:debug": "npm run android:prepare && node scripts/with-android-java.mjs ./android/gradlew -p android assembleDebug",
    "android:build:release:apk": "npm run android:prepare && node scripts/with-android-java.mjs ./android/gradlew -p android assembleRelease",
    "android:build:release:bundle": "npm run android:prepare && node scripts/with-android-java.mjs ./android/gradlew -p android bundleRelease",
    "android:install:release": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "ios:assets": "npx @capacitor/assets generate --ios --iconBackgroundColor '#ff5b2c' --iconBackgroundColorDark '#140904' --splashBackgroundColor '#f4efe6' --splashBackgroundColorDark '#12100d'",
    "ios:sync": "npm run content:build",
    "ios:open": "open ios/App/App.xcodeproj",
    "ios:prepare": "npm run content:build && npm run ios:assets",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:ci": "npm run lint && npm run typecheck && npm run test && npm run build && npm run build:mobile && npm run android:test",
    "swift-core:test": "swift test --package-path shared/swift-core"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "clsx": "^2.1.1",
    "flexsearch": "^0.8.212",
    "gray-matter": "^4.0.3",
    "next": "16.1.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@csstools/postcss-cascade-layers": "^6.0.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4",
    "wrangler": "^4.75.0"
  }
}
